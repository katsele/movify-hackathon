# ----- Supabase (frontend, injected into the browser) ---------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----- Supabase (Python workers, write access) ----------------------------
# The worker reads SUPABASE_URL first, then falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Boond CRM ----------------------------------------------------------
# Boondmanager API base. Defaults to the SaaS endpoint if unset.
BOOND_API_BASE=https://ui.boondmanager.com/api

# Pick ONE auth scheme below (the connector tries x-Jwt-Client first, then Basic).
#
# Scheme A — x-Jwt-Client-BoondManager (recommended)
#   Triple secrets from: Admin > Dashboard (or User > Settings > Security)
#   clientKey is the HS256 signing secret; clientToken + userToken go in the JWT payload.
BOOND_USER_TOKEN=
BOOND_CLIENT_TOKEN=
BOOND_CLIENT_KEY=

# Scheme B — HTTP Basic (email + password of a Boond account with API access enabled)
BOOND_USERNAME=
BOOND_PASSWORD=
