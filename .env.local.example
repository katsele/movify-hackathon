# ----- Supabase (frontend, injected into the browser) ---------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----- Supabase (Python workers, write access) ----------------------------
# The worker reads SUPABASE_URL first, then falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Boond CRM ----------------------------------------------------------
# Pick ONE mode:
#   1) API mode — set BOOND_API_BASE + one of the auth schemes below
#   2) Export mode — set BOOND_EXPORT_DIR to a folder of CSV/JSON exports
#
# Boondmanager's API is typically https://ui.boondmanager.com/api
BOOND_API_BASE=https://ui.boondmanager.com/api

# Auth scheme A — single bearer / JWT token
BOOND_API_TOKEN=

# Auth scheme B — Boondmanager's classic triple-token (X-Jwt-Client-BoondManager)
# Leave blank unless you were issued separate client/user keys.
BOOND_CLIENT_KEY=
BOOND_USER_TOKEN=
BOOND_APP_KEY=

# Export mode (fallback when API access is not available)
BOOND_EXPORT_DIR=
